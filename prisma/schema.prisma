datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String   @id @default(cuid())
  clerkId             String   @unique
  fullName            String?
  email               String   @unique
  imageUrl            String?
  dreamRole           String?
  skills              String[]
  githubUrl           String?
  linkedinUrl         String?
  resumeUrl           String?
  dailyStudyTime      Int?
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
